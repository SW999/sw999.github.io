{
  "name": "nodejs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev-server": "nodemon server/index.js --watch-poll server",
    "dev-web": "webpack-dev-server --config ./webpack-dev.config.js --progress --colors --content-base build --port 3000 --host 0.0.0.0",
    "dev": "npm cache clear & npm run dev-web & npm run dev-server",
    "build": "webpack --config ./webpack-prod.config.js --progress --colors",
    "start": "node server/index.js",
    "start_old": "node ./bin/www"
  },
  "dependencies": {
    "body-parser": "~1.15.2",
    "cookie-parser": "~1.4.3",
    "debug": "~2.2.0",
    "express": "~4.14.0",
    "jade": "~1.11.0",
    "method-override": "^2.3.7",
    "mongoose": "^4.7.5",
    "morgan": "~1.7.0",
    "nconf": "^0.8.4",
    "node-sass-middleware": "0.9.8",
    "serve-favicon": "~2.3.0",
    "winston": "^2.3.0",
    "mongoose-url-slugs": "^0.2.1",


    "babel-core": "^5.5.8",
    "babel-loader": "^5.1.4",
    "babel-runtime": "^5.5.8",
    "nodemon": "^1.11.0",
    "react": "~15.2.1",
    "react-dom": "15.2.1",
    "react-hot-loader": "^1.3.0",
    "react-loader": "^2.4.0",
    "react-router": "^2.0.1",
    "html-webpack-plugin": "^1.5.2",
    "image-webpack-loader": "^1.6.3",
